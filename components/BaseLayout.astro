---
import Header from "./Header.astro"
import Footer from "./Footer.astro"
import "../styles/tokens.css"
import "../styles/base.css"

interface NavItem {
  label: string
  href: string
}

interface Article {
  section: string
  published: string
  modified: string
  wordCount: number
  keywords: string[]
}

interface Props {
  title?: string | null // page title; empty on home
  description?: string
  canonical?: string
  image?: string
  article?: Article
  isPage?: boolean // content page: full schema meta
  externalUrl?: string // project pages: meta-refresh redirect
  siteTitle?: string
  tagline?: string
  nav?: NavItem[]
  author?: string
  lang?: string
  dir?: "ltr" | "rtl"
  rssHref?: string
  cloudflareToken?: string
}

const {
  title,
  description = "Visual journalist/hacker covering AI",
  canonical,
  image = "https://www.kschaul.com/social.jpg",
  article,
  isPage = false,
  externalUrl,
  siteTitle = "Kevin Schaul",
  tagline,
  nav,
  author = siteTitle,
  lang = "en-us",
  dir = "ltr",
  rssHref = "/index.xml",
  cloudflareToken,
} = Astro.props

const fullTitle = title ? `${title} - ${siteTitle}` : siteTitle
---

<!doctype html>
<html class="not-ready" lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, shrink-to-fit=no"
    />

    <title>{fullTitle}</title>

    <meta name="theme-color" />

    <meta name="description" content={description} />
    <meta name="author" content={author} />

    <link rel="icon" href="/favicon.ico" />

    <meta itemprop="name" content={title || siteTitle} />
    <meta itemprop="description" content={description} />
    {
      article && (
        <>
          <meta itemprop="datePublished" content={article.published} />
          <meta itemprop="dateModified" content={article.modified} />
          <meta itemprop="wordCount" content={String(article.wordCount)} />
        </>
      )
    }
    <meta itemprop="image" content={image} />
    {
      article && article.keywords.length > 0 && (
        <meta itemprop="keywords" content={article.keywords.join(",") + ","} />
      )
    }

    <meta property="og:title" content={title || siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={article ? "article" : "website"} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={image} />
    {
      article && (
        <>
          <meta property="article:section" content={article.section} />
          <meta
            property="article:published_time"
            content={article.published}
          />
          <meta property="article:modified_time" content={article.modified} />
        </>
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:title" content={title || siteTitle} />
    <meta name="twitter:description" content={description} />

    <link
      rel="alternate"
      type="application/rss+xml"
      href={rssHref}
      title={siteTitle}
    />

    {
      externalUrl ? (
        <>
          <meta http-equiv="refresh" content={`0; url=${externalUrl}`} />
          <link rel="canonical" href={externalUrl} />
        </>
      ) : (
        canonical && <link rel="canonical" href={canonical} />
      )
    }

    {
      cloudflareToken && (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: cloudflareToken })}
          is:inline
        />
      )
    }

    <slot name="head" />
  </head>
  <body>
    <Header siteTitle={siteTitle} tagline={tagline} nav={nav} />

    <main class="t-main t-container">
      <slot />
    </main>

    <Footer siteTitle={siteTitle} />
  </body>
</html>
